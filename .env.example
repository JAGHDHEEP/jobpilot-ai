# ---- App
ENV=dev
SECRET_KEY=please-generate-a-32+-byte-random-secret

# ---- Postgres
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot
POSTGRES_DB=jobpilot

# ---- AI (use "mock" for offline dev; switch to openai/anthropic with a key)
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000

# ---- Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
